# EP-Online V5 API key. Register (free) at https://public.ep-online.nl to request one.
# Without this key the server fails to start. BAG + EP-Online are presented as
# a single composite tool on purpose, so agents always see the full picture.
EP_ONLINE_API_KEY=

# Port for the optional streamable-HTTP transport (src/http.ts).
# Default: 3000. stdio transport (src/index.ts) does not use this.
PORT=3000
